{
  "compilerOptions": {
    "target": "ES6",
    "module": "Node16",           /* Cambia esto a Node16 */
    "moduleResolution": "Node16", /* Esto ya lo tienes en Node16 */
    
    "ignoreDeprecations": "5.0",
    "rootDir": "./",
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "types": ["node"],
    "esModuleInterop": true
  }
}